---
export interface Props {
    title: string;
    description: string;
    tags?: string[];
    href?: string;
    class?: string;
    style?: string;
    minimal?: boolean;
    titleStyle?: string;
    descStyle?: string;
}

const {
    title,
    description,
    tags = [],
    href,
    class: className,
    style,
    minimal = false,
} = Astro.props;
const Element = href ? "a" : "div";
---

<Element
    href={href}
    class:list={[
        "work-card",
        { minimal: minimal, "no-link": !href },
        className,
    ]}
    style={style}
    target={href ? "_blank" : undefined}
    rel={href ? "noopener noreferrer" : undefined}
    aria-label={href ? `${title} の詳細を新しいタブで開く` : undefined}
>
    {
        minimal ? (
            <h3 class="work-title-minimal">
                {title}
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="external-icon"
                >
                    <>
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                        <polyline points="15 3 21 3 21 9" />
                        <line x1="10" y1="14" x2="21" y2="3" />
                    </>
                </svg>
            </h3>
        ) : (
            <>
                <h3>{title}</h3>
                <p class="work-desc" set:html={description} />
                {tags.length > 0 && (
                    <div class="tags">
                        {tags.map((tag) => (
                            <span class="tag">{tag}</span>
                        ))}
                    </div>
                )}
            </>
        )
    }
</Element>

<style>
    .work-title-minimal {
        text-align: left;
        margin: 0;
        width: 100%;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .external-icon {
        opacity: 0.4;
        flex-shrink: 0;
    }

    .work-card.minimal:hover .external-icon {
        opacity: 1;
    }
</style>
