---
import "../styles/global.css";
import { Image } from "astro:assets";
import avatarImg from "../../public/avatar.webp";
import GrainientBackground from "../components/GrainientBackground.jsx";

export interface Props {
	title?: string;
	description?: string;
	image?: string;
	isErrorPage?: boolean;
	lang?: "ja" | "en";
	structuredData?: object;
}

const {
	title = "manpuc | Student Developer & UI/UX Designer",
	description = "まんぷく（manpuc）のポートフォリオ。Minecraft Mod制作、Web開発、Discord Bot制作を専門とする学生・デベロッパーの制作実績を公開中。",
	image = "/avatar.webp",
	isErrorPage = false,
	lang = "ja",
	structuredData,
} = Astro.props;

const siteUrl = "https://manpuc.me";
// Remove trailing slashes and common prefixes to get a clean path for canonicals
const cleanPath = Astro.url.pathname.replace(/\/$/, "").replace(/^\/en/, "");
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const imageUrl = new URL(image, siteUrl);

// i18n relative paths
const jaPath = cleanPath === "" ? "/" : cleanPath;
const enPath = `/en${cleanPath}`;

// Merge default Person structured data with page-specific data
const defaultPersonData = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: "manpuc",
	alternateName: ["manpuc", "まんぷく"],
	url: siteUrl,
	image: `${siteUrl}/avatar.webp`,
	sameAs: [
		"https://github.com/manpuc",
		"https://twitter.com/manpuccc",
		"https://modrinth.com/user/manpuc",
		"https://chromewebstore.google.com/author/manpuc",
	],
	jobTitle: lang === "ja" ? "学生 / デベロッパー" : "Student / Developer",
	description:
		lang === "ja"
			? "まんぷく（manpuc）のポートフォリオ。Minecraft Mod制作、Web開発、Bot制作を専門とする学生・デベロッパー。"
			: "Student and developer specializing in Minecraft Modding, Web Development, and Bot Development.",
	knowsAbout: [
		"Minecraft Mod Development",
		"Web Development",
		"Astro",
		"React",
		"TypeScript",
		"JavaScript",
		"Discord Bot Development",
		"Node.js",
		"Python",
	],
};

const finalStructuredData = Array.isArray(structuredData)
	? [defaultPersonData, ...structuredData]
	: structuredData
		? [defaultPersonData, structuredData]
		: defaultPersonData;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="manifest" href="/manifest.json" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="manpuc" />
		<meta name="robots" content="index, follow" />

		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:site_name" content="manpuc" />
		<meta
			property="og:locale"
			content={lang === "ja" ? "ja_JP" : "en_US"}
		/>

		<meta name="theme-color" content="#1A1B26" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@manpuccc" />
		<meta name="twitter:creator" content="@manpuccc" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />

		<!-- Hreflang Tags -->
		<link rel="alternate" hreflang="ja" href={new URL(jaPath, siteUrl)} />
		<link rel="alternate" hreflang="en" href={new URL(enPath, siteUrl)} />
		<link
			rel="alternate"
			hreflang="x-default"
			href={new URL(jaPath, siteUrl)}
		/>

		<!-- ▼ SEO ▼ -->
		<meta
			name="keywords"
			content="manpuc,まんぷく,ポートフォリオ,エンジニア,Minecraft Mod 制作依頼,Web制作,Discord Bot 開発,Java,Astro,TypeScript"
		/>
		<link rel="canonical" href={canonicalURL} />
		<link rel="dns-prefetch" href="https://fonts.googleapis.com" />
		<link rel="dns-prefetch" href="https://fonts.gstatic.com" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<!-- Async font loading for performance and caching -->
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@400;500;700&family=JetBrains+Mono:wght@400&display=swap"
			media="print"
			onload="this.media='all'"
		/>

		<link rel="sitemap" href="/sitemap-index.xml" />
		<!-- ▲▲▲▲▲▲▲ -->
		<link
			rel="preload"
			href="/avatar.webp"
			as="image"
			fetchpriority="high"
		/>

		<!-- JSON-LD 構造化データ -->
		<script
			type="application/ld+json"
			set:html={JSON.stringify(finalStructuredData)}
		/>
	</head>

	<body class={lang === "en" ? "light en-mode" : "light"}>
		<GrainientBackground client:only="react" className="" />
		<!-- SVG Filter -->
		<svg width="0" height="0" style="position: absolute;">
			<defs>
				<filter
					id="glass-distortion"
					x="0%"
					y="0%"
					width="100%"
					height="100%"
				>
					<feTurbulence
						type="fractalNoise"
						baseFrequency="0.006 0.006"
						numOctaves="2"
						seed="92"
						result="noise"></feTurbulence>
					<feGaussianBlur in="noise" stdDeviation="2" result="blurred"
					></feGaussianBlur>
					<feDisplacementMap
						in="SourceGraphic"
						in2="blurred"
						scale="65"
						xChannelSelector="R"
						yChannelSelector="G"></feDisplacementMap>
				</filter>
			</defs>
		</svg>

		<!-- Theme Toggle -->
		<button class="theme-toggle" id="themeToggle" aria-label="Toggle Theme">
			<div class="icon-container">
				<svg
					class="sun-icon"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2.5"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<circle cx="12" cy="12" r="5"></circle>
					<line x1="12" y1="1" x2="12" y2="3"></line>
					<line x1="12" y1="21" x2="12" y2="23"></line>
					<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
					<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
					<line x1="1" y1="12" x2="3" y2="12"></line>
					<line x1="21" y1="12" x2="23" y2="12"></line>
					<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
					<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
				</svg>
				<svg
					class="moon-icon"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2.5"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
					></path>
				</svg>
			</div>
		</button>

		<!-- Language Toggle (Now a Link for SEO) -->
		<a
			href={lang === "ja" ? enPath : jaPath}
			class="theme-toggle"
			id="langToggle"
			aria-label={lang === "ja"
				? "Switch to English"
				: "日本語に切り替え"}
			style="right: 110px;"
		>
			<div class="icon-container">
				<svg class="lang-icon-en" viewBox="0 0 24 24">
					<text
						x="50%"
						y="54%"
						dominant-baseline="middle"
						text-anchor="middle"
						fill="currentColor"
						font-family="'JetBrains Mono', monospace"
						font-weight="700"
						font-size="11"
						letter-spacing="0.5px">EN</text
					>
				</svg>
				<svg class="lang-icon-ja" viewBox="0 0 24 24">
					<text
						x="50%"
						y="54%"
						dominant-baseline="middle"
						text-anchor="middle"
						fill="currentColor"
						font-family="'JetBrains Mono', monospace"
						font-weight="700"
						font-size="11"
						letter-spacing="0.5px">JA</text
					>
				</svg>
			</div>
		</a>

		<!-- Contact FAB -->
		<a
			href="/#contact"
			class="contact-fab"
			id="contactFab"
			aria-label="Go to Contact"
		>
			<svg
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2.5"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<path
					d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
				></path>
				<polyline points="22,6 12,13 2,6"></polyline>
			</svg>
		</a>

		<!-- Scroll Top FAB -->
		{
			!isErrorPage && (
				<button
					class="scroll-top-fab absorbed"
					id="scrollTopFab"
					aria-label="Scroll to Top"
				>
					<svg
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="3"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<polyline points="18 15 12 9 6 15" />
					</svg>
				</button>
			)
		}

		<!-- ▼ SLOT ▼ -->
		<slot />
		<!-- ▲ SLOT ▲ -->

		<!-- Footer -->
		<footer class="site-footer">
			<div class="footer-content">
				<div class="footer-logo">
					<Image
						src={avatarImg}
						width={88}
						height={88}
						alt="manpuc"
						class="footer-avatar"
						loading="lazy"
						decoding="async"
						oncontextmenu="return false;"
					/>
					<div class="footer-title">
						<h3>manpuc</h3>
						<p class="txt-ja">学生・デベロッパー・クリエイター</p>
						<p class="txt-en">Student / Developer / Creator</p>
					</div>
				</div>

				<div class="footer-right">
					<div class="footer-nav">
						<a href="/#about"
							><span class="txt-ja">概要</span><span
								class="txt-en">About</span
							></a
						>
						<a href="/works/"
							><span class="txt-ja">実績</span><span
								class="txt-en">Works</span
							></a
						>
						<a href="/#contact"
							><span class="txt-ja">お問い合わせ</span><span
								class="txt-en">Contact</span
							></a
						>
						<a href={lang === "ja" ? "/terms/" : "/en/terms/"}
							><span class="txt-ja">利用規約</span><span
								class="txt-en">Terms</span
							></a
						>
					</div>

					<div class="footer-socials">
						<a
							href="mailto:info@manpuc.me"
							aria-label="Email"
							class="social-icon"
						>
							<svg
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path
									d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
								></path>
								<polyline points="22,6 12,13 2,6"></polyline>
							</svg>
						</a>
						<a
							href="https://github.com/manpuc"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="GitHub"
							class="social-icon"
						>
							<svg
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path
									d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
								></path>
							</svg>
						</a>
						<a
							href="https://twitter.com/manpuccc"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Twitter"
							class="social-icon"
						>
							<svg
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path
									d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"
								></path>
							</svg>
						</a>
					</div>
				</div>
			</div>
			<div class="footer-bottom">
				<p>&copy; 2026 manpuc. All Rights Reserved.</p>
			</div>
		</footer>

		<script>
			if (
				typeof window !== "undefined" &&
				typeof navigator !== "undefined"
			) {
				// ==========================================
				// 1. 言語切り替え (URL遷移版)
				// ==========================================
				// Note: リンクとして実装したため、JSでの切り替えロジックは最小限（初期読み込み時のクラス調整のみ）
				const savedLang = localStorage.getItem("portfolio-lang");
				const currentPath = window.location.pathname;

				// 初回アクセス時などのリダイレクト判定は行わず、ユーザーの選択を尊重する
				// ただし、明示的に切り替えた場合はlocalStorageを更新する
				if (currentPath.startsWith("/en")) {
					localStorage.setItem("portfolio-lang", "en");
				} else {
					localStorage.setItem("portfolio-lang", "ja");
				}

				// ==========================================
				// 2. テーマ切り替え
				// ==========================================
				const toggleBtn = document.getElementById("themeToggle");
				const body = document.body;
				const savedTheme = localStorage.getItem("portfolio-theme");
				const osDark = window.matchMedia(
					"(prefers-color-scheme: dark)",
				).matches;

				if (savedTheme === "dark" || (!savedTheme && osDark)) {
					body.classList.add("dark");
					body.classList.remove("light");
				}

				if (toggleBtn) {
					toggleBtn.addEventListener("click", () => {
						if (body.classList.contains("dark")) {
							body.classList.remove("dark");
							body.classList.add("light");
							localStorage.setItem("portfolio-theme", "light");
						} else {
							body.classList.remove("light");
							body.classList.add("dark");
							localStorage.setItem("portfolio-theme", "dark");
						}
					});
				}

				// ==========================================
				// 3. アニメーション用オブザーバー
				// ==========================================
				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add("visible");
							}
						});
					},
					{ threshold: 0.15, rootMargin: "0px 0px -40px 0px" },
				);

				document
					.querySelectorAll(".reveal")
					.forEach((el) => observer.observe(el));

				// ==========================================
				// 4. Contactアイコンのアニメーション
				// ==========================================
				const animClasses = [
					"rand-bounce",
					"rand-spin",
					"rand-shake",
					"rand-pop",
				];
				// Target all contact buttons and FABs
				document.querySelectorAll(".contact-links a")
					.forEach((btn) => {
						// Handle cases where the class is on the 'a' tag or the container
						const icon = btn.querySelector("svg");
						if (!icon) return;

						btn.addEventListener("mouseenter", function () {
							animClasses.forEach((c) =>
								icon.classList.remove(c),
							);
							void (icon as any).offsetWidth;
							const randomAnim =
								animClasses[
									Math.floor(
										Math.random() * animClasses.length,
									)
								];
							icon.classList.add(randomAnim);
						});
						btn.addEventListener("mouseleave", function () {
							animClasses.forEach((c) =>
								icon.classList.remove(c),
							);
						});
					});

				// ==========================================
				// 5. FABの処理
				// ==========================================
				const contactFab = document.getElementById("contactFab");
				const scrollTopFab = document.getElementById("scrollTopFab");
				const contactSection = document.getElementById("contact");

				if (contactFab && scrollTopFab) {
					if (contactSection) {
						const fabObserver = new IntersectionObserver(
							(entries) => {
								entries.forEach((entry) => {
									if (entry.isIntersecting) {
										contactFab.classList.add("absorbed");
										setTimeout(
											() =>
												scrollTopFab.classList.remove(
													"absorbed",
												),
											200,
										);
									} else {
										scrollTopFab.classList.add("absorbed");
										setTimeout(
											() =>
												contactFab.classList.remove(
													"absorbed",
												),
											200,
										);
									}
								});
							},
							{ threshold: 0.1 },
						);
						fabObserver.observe(contactSection);
					} else {
						window.addEventListener("scroll", () => {
							if (window.scrollY > 300) {
								contactFab.classList.add("absorbed");
								setTimeout(
									() =>
										scrollTopFab.classList.remove(
											"absorbed",
										),
									200,
								);
							} else {
								scrollTopFab.classList.add("absorbed");
								setTimeout(
									() =>
										contactFab.classList.remove("absorbed"),
									200,
								);
							}
						});
					}

					scrollTopFab.addEventListener("click", () => {
						window.scrollTo({ top: 0, behavior: "smooth" });
					});
				}

				// ==========================================
				// 6. プロフィール画像のアニメーション
				// ==========================================
				const profileImg = document.querySelector(".profile-img") as HTMLElement;
				if (profileImg) {
					profileImg.style.transformOrigin = "center";
					profileImg.style.willChange = "transform, box-shadow";

					const handleMove = (e: any) => {
						if (e.type === "touchmove") {
							e.preventDefault();
						}

						requestAnimationFrame(() => {
							const rect = profileImg.getBoundingClientRect();

							const clientX = e.touches
								? e.touches[0].clientX
								: e.clientX;
							const clientY = e.touches
								? e.touches[0].clientY
								: e.clientY;

							const x =
								(clientX - rect.left - rect.width / 2) /
								(rect.width / 2);
							const y =
								(clientY - rect.top - rect.height / 2) /
								(rect.height / 2);

							const rotateX = -y * 25;
							const rotateY = x * 25;
							const shadowX = -x * 20;
							const shadowY = -y * 20;

							profileImg.style.transition =
								"transform 0.1s ease-out, box-shadow 0.1s ease-out";
							profileImg.style.transform = `perspective(1000px) scale(1.1) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
							profileImg.style.boxShadow = `${shadowX}px ${shadowY + 15}px 40px rgba(122, 162, 246, 0.6)`;
						});
					};

					const handleReset = () => {
						profileImg.style.transition =
							"transform 0.6s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.6s ease";
						profileImg.style.transform = `perspective(1000px) scale(1) rotateX(0deg) rotateY(0deg)`;
						profileImg.style.boxShadow = `0 15px 35px rgba(122, 162, 246, 0.4)`;
					};

					profileImg.addEventListener("mousemove", handleMove);
					profileImg.addEventListener("mouseleave", handleReset);

					profileImg.addEventListener("touchmove", handleMove, {
						passive: false,
					});
					profileImg.addEventListener("touchend", handleReset);
					profileImg.addEventListener("touchcancel", handleReset);
				}
			}
		</script>
	</body>
</html>
