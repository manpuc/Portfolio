---
import "../styles/global.css";
import { Image } from "astro:assets";
import avatar from "../../public/avatar.webp";
import MinesweeperGame from "../components/MinesweeperGame.astro";
import FlappyBirdGame from "../components/FlappyBirdGame.astro";

export interface Props {
	title?: string;
	description?: string;
	image?: string;
	isErrorPage?: boolean;
	lang?: "ja" | "en";
	structuredData?: object;
}

const {
	title = "manpuc | Student Developer & UI/UX Designer",
	description = "まんぷく（manpuc）のポートフォリオ。Minecraft Mod制作、Web開発、Discord Bot制作を専門とする学生・デベロッパーの制作実績を公開中。",
	image = "/avatar.webp",
	lang = "ja",
	structuredData,
} = Astro.props;

const siteUrl = "https://manpuc.me";
const cleanPath = Astro.url.pathname.replace(/\/$/, "").replace(/^\/en/, "");
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const imageUrl = new URL(image, siteUrl);

const jaPath = cleanPath === "" ? "/" : cleanPath;
const enPath = `/en${cleanPath}`;

const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "/en" || Astro.url.pathname === "/en/";
const footerDelay = isHome ? 2500 : 300;
const footerStagger = isHome ? 120 : 60;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="manpuc" />

		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={imageUrl} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@manpuccc" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />

		<link rel="alternate" hreflang="ja" href={new URL(jaPath, siteUrl)} />
		<link rel="alternate" hreflang="en" href={new URL(enPath, siteUrl)} />
		<link rel="canonical" href={canonicalURL} />
		{structuredData && (
			<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
		)}
		<link
			rel="stylesheet"
			type="text/css"
			href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css"
		/>
	</head>

	<body>
		<div class="floating-controls">
			<a
				href={lang === "ja" ? enPath : jaPath}
				class="icon-btn animate-rotate-in delay-float-1"
				aria-label={lang === "ja"
					? "Switch to English"
					: "日本語に切り替え"}
			>
				<span style="font-weight: 700; font-size: 0.8rem;"
					>{lang === "ja" ? "EN" : "JA"}</span
				>
			</a>
			<button
				id="themeToggle"
				class="icon-btn animate-rotate-in delay-float-2"
				aria-label="テーマを切り替え"
			>
				<svg
					class="theme-icon-sun"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					role="img"
					aria-label="ライトモード"
				>
					<circle cx="12" cy="12" r="5"></circle>
					<line x1="12" y1="1" x2="12" y2="3"></line>
					<line x1="12" y1="21" x2="12" y2="23"></line>
					<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
					<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
					<line x1="1" y1="12" x2="3" y2="12"></line>
					<line x1="21" y1="12" x2="23" y2="12"></line>
					<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
					<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
				</svg>
				<svg
					class="theme-icon-moon"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					role="img"
					aria-label="ダークモード"
				>
					<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
					></path>
				</svg>
			</button>
		</div>

		<slot />

		<div
			class="container animate-fade-up delay-6"
			style="padding-top: 0; padding-bottom: 0;"
		>
			<div class="header-divider" style="margin-bottom: 0;"></div>
		</div>

		<footer class="site-footer" data-delay={footerDelay} data-stagger={footerStagger}>
			<div class="footer-main-layout">
				<div class="footer-profile">
					<div class="footer-reveal-item" data-anim="kururin">
						<Image
							src={avatar}
							alt="manpuc"
							width={44}
							height={44}
							class="footer-avatar"
						/>
					</div>
					<div class="footer-profile-text footer-reveal-item" data-anim="pyoko">
						<span class="footer-name">manpuc</span>
						<span class="footer-handle">@manpuc / Developer & Creator</span>
					</div>
				</div>

				<div class="footer-links-group">
					<div class="footer-nav-text">
						<a href={lang === "ja" ? "/" : "/en/"} class="footer-reveal-item" data-anim="pyoko"
							>{lang === "ja" ? "ホーム" : "Home"}</a
						>
						<a href={lang === "ja" ? "/works/" : "/en/works/"} class="footer-reveal-item" data-anim="pyoko"
							>{lang === "ja" ? "作品集" : "Works"}</a
						>
						<a href={lang === "ja" ? "/terms/" : "/en/terms/"} class="footer-reveal-item" data-anim="pyoko"
							>{lang === "ja" ? "利用規約" : "Terms"}</a
						>
					</div>
					<div class="contact-links-footer">
						<a
							href="mailto:info@manpuc.me"
							class="icon-btn-footer footer-reveal-item"
							data-anim="pyoko"
							aria-label="Email"
						>
							<svg
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								role="img"
								aria-label="メールを送る"
								><path
									d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
								></path><polyline points="22,6 12,13 2,6"
								></polyline></svg
							>
						</a>
						<a
							href="https://github.com/manpuc"
							target="_blank"
							rel="noopener noreferrer"
							class="icon-btn-footer footer-reveal-item"
							data-anim="pyoko"
							aria-label="GitHub"
						>
							<i class="devicon-github-original"></i>
						</a>
						<a
							href="https://twitter.com/manpuccc"
							target="_blank"
							rel="noopener noreferrer"
							class="icon-btn-footer footer-reveal-item"
							data-anim="pyoko"
							aria-label="Twitter"
						>
							<svg
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								role="img"
								aria-label="Twitter (X) を見る"
								><path
									d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"
								></path></svg
							>
						</a>
					</div>
				</div>
			</div>

			<div class="container" style="padding-top: 0; padding-bottom: 0;">
				<div class="footer-bottom footer-reveal-item" data-anim="pyoko">
					<p>&copy; 2026 manpuc. Designed & Developed.</p>
				</div>
			</div>
		</footer>

		<MinesweeperGame />
		<FlappyBirdGame />

		<script>
			if (typeof window !== "undefined") {
				const body = document.body;
				const toggleBtn = document.getElementById("themeToggle");
				const savedTheme = localStorage.getItem("portfolio-theme");
				const osDark = window.matchMedia(
					"(prefers-color-scheme: dark)",
				).matches;

				if (savedTheme === "dark" || (!savedTheme && osDark)) {
					body.classList.add("dark");
				}

				if (toggleBtn) {
					toggleBtn.addEventListener("click", () => {
						body.classList.toggle("dark");
						localStorage.setItem(
							"portfolio-theme",
							body.classList.contains("dark") ? "dark" : "light",
						);
					});
				}

				// Footer Fun Staggered Animation Logic
				const footerItems = document.querySelectorAll('.footer-reveal-item');
				const siteFooter = document.querySelector('.site-footer') as HTMLElement;
				
				const startFooterAnimation = () => {
					const baseDelay = parseInt(siteFooter?.dataset.delay || "300");
					const stagger = parseInt(siteFooter?.dataset.stagger || "60");

					footerItems.forEach((item, index) => {
						const el = item as HTMLElement;
						const animType = el.dataset.anim;
						const animationClass = animType === 'kururin' ? 'animate-kururin' : 'animate-pyoko';
						
						setTimeout(() => {
							el.classList.add(animationClass);
						}, baseDelay + (index * stagger));
					});
				};

				// Trigger on scroll or load
				const footerObserver = new IntersectionObserver((entries) => {
					if (entries[0].isIntersecting) {
						startFooterAnimation();
						footerObserver.disconnect();
					}
				}, { threshold: 0.1 });

				if (siteFooter) footerObserver.observe(siteFooter);
			}
		</script>
	</body>
</html>
