---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import avatarImg from "../../../public/avatar.webp";
---

<Layout title="manpuc - Portfolio" lang="en">
    <div class="container">
        <!-- Header -->
        <header class="reveal">
            <Image
                src={avatarImg}
                width={245}
                height={245}
                alt="manpuc"
                class="profile-img"
                loading="eager"
                fetchpriority="high"
                decoding="async"
                sizes="(max-width: 768px) 180px, 245px"
                oncontextmenu="return false;"
                style="transform-origin: center; will-change: transform, box-shadow;"
            />
            <h1>manpuc</h1>
            <p class="subtitle">@manpuc / Developer & Creator</p>
        </header>

        <!-- Navigation -->
        <nav class="reveal" style="transition-delay: 0.1s;">
            <a href="#about">About</a>
            <a href="#skills">Skills</a>
            <a href="#works">Works</a>
            <a href="#contact">Contact</a>
        </nav>

        <!-- About Section -->
        <section id="about" class="reveal" style="transition-delay: 0.2s;">
            <h2>About</h2>
            <div class="profile-text">
                <ul>
                    <li>
                        Graduated from Commercial High School (Information Design) / Enrolled in The Open University of Japan
                    </li>
                    <li>
                        Gadget collector (Smartwatches, Smartphones, Earphones, etc.)
                    </li>
                    <li>
                        Minecraft Modding (Java/Forge), Bot Development, Chrome Extensions
                    </li>
                    <li>
                        I love new technologies and creating things
                    </li>
                </ul>
            </div>
        </section>

        <!-- Skills Section -->
        <section id="skills" class="reveal">
            <h2>Skills</h2>
            <div class="skills-grid">
                <div class="skill-item">
                    <h3>Dev & Code</h3>
                    <ul>
                        <li>Python</li>
                        <li>PowerShell, Batch Scripting</li>
                        <li>Java (Minecraft Forge 1.20.1)</li>
                    </ul>
                </div>
                <div class="skill-item">
                    <h3>Web Development</h3>
                    <ul>
                        <li>HTML / CSS / JavaScript</li>
                        <li>Astro, React, Node.js</li>
                        <li>UI/UX & Modern Animations</li>
                    </ul>
                </div>
                <div class="skill-item">
                    <h3>Tools & Others</h3>
                    <ul>
                        <li>Git, GitHub, pnpm</li>
                        <li>Generative AI Tools</li>
                        <li>
                            After Effects
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- Works Section -->
        <section id="works" class="reveal">
            <h2>Works</h2>
            <div class="works-grid">
                <a href="/en/" class="work-item" target="_blank" rel="noopener">
                    <h3 style="margin-bottom: 5px;">
                        Portfolio Website<span
                            style="font-size: 12px; color: var(--txt-sub);padding-left: 6px;"
                            >This Site</span
                        >
                    </h3>
                    <p style="color: var(--txt-sub); font-size: 0.9em;">
                        A website with a focus on cozy UI
                    </p>
                </a>
                <a
                    href="https://modrinth.com/user/manpuc"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h3 style="margin-bottom: 5px;">Minecraft Mod</h3>
                    <p style="color: var(--txt-sub); font-size: 0.9em;">
                        Custom Mod development for Forge.
                    </p>
                </a>
                <a
                    href="https://github.com/manpuc/MBot"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h3 style="margin-bottom: 5px;">Custom Discord Bot</h3>
                    <p style="color: var(--txt-sub); font-size: 0.9em;">
                        Multi-functional Discord Bot.
                    </p>
                </a>
                <a
                    href="https://chromewebstore.google.com/detail/ganlcelmnoaidpmaegcmhecolonfmffk?utm_source=item-share-cb"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h3 style="margin-bottom: 5px;">Chrome Theme</h3>
                    <p style="color: var(--txt-sub); font-size: 0.9em;">
                        An eye-friendly Chrome dark theme
                    </p>
                </a>
            </div>

            <div class="view-more-container">
                <a href="/en/works/" class="btn-view-more">
                    View All
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        style="width: 20px; height: 20px;"
                    >
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </a>
            </div>
        </section>

        <!-- Contact Section -->
        <section id="contact" class="reveal">
            <h2>Contact</h2>
            <div class="contact-links">
                <a href="mailto:info@manpuc.me" class="btn-email">
                    <svg
                        class="contact-icon email-icon"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                        ></path>
                        <polyline points="22,6 12,13 2,6"></polyline>
                    </svg>
                    Email
                </a>
                <a
                    href="https://github.com/manpuc"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-github"
                >
                    <svg
                        class="contact-icon github-icon"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
                        ></path>
                    </svg>
                    GitHub
                </a>
                <a
                    href="https://twitter.com/manpuccc"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-twitter"
                >
                    <svg
                        class="contact-icon twitter-icon"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"
                        ></path>
                    </svg>
                    Twitter
                </a>
            </div>
        </section>
    </div>
</Layout>
