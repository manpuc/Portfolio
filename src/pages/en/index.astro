---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import avatarImg from "../../../public/avatar.webp";
import { works } from "../../data/works";
import TechIcon from "../../components/TechIcon.astro";
import { devSkills, toolSkills } from "../../data/skills";

// Helper to convert devicon class to simple TechIcon keys
const getIconName = (deviconClass: string) => {
    const mapping: Record<string, string> = {
        "devicon-html5-plain": "html",
        "devicon-css3-plain": "css",
        "devicon-javascript-plain": "javascript",
        "devicon-astro-plain": "astro",
        "devicon-react-original": "react",
        "devicon-nodejs-plain": "nodejs",
        "devicon-python-plain": "python",
        "devicon-bash-plain": "powershell",
        "devicon-java-plain": "java",
        "devicon-git-plain": "git",
        "devicon-github-original": "github",
        "devicon-vscode-plain": "vscode",
        "devicon-aftereffects-plain": "aftereffects",
        "devicon-illustrator-plain": "illustrator",
    };
    return mapping[deviconClass] || "html";
};
---

<Layout title="manpuc | Student Developer & UI/UX Designer" lang="en">
    <div class="container">
        <header
            style="display: flex; align-items: center; gap: 2rem; margin-bottom: 2rem;"
        >
            <div class="animate-profile-pop delay-profile">
                <Image
                    src={avatarImg}
                    width={150}
                    height={150}
                    alt="manpuc"
                    class="profile-img"
                />
            </div>
            <div
                id="header-info-en"
                class="header-info animate-premium-reveal delay-header-info"
            >
                <h1>
                    <span class="typewriter-container">
                        <span class="typewriter-text" data-text="manpuc"></span>
                        <span class="typewriter-cursor"></span>
                    </span>
                </h1>
                <p class="subtitle">@manpuc / Developer & Creator</p>
            </div>
        </header>

        <div class="header-divider animate-premium-reveal delay-divider"></div>

        <section
            id="works"
            class="animate-fade-up delay-3"
            style="margin-bottom: 4rem; padding: 0 1rem;"
        >
            <h2>Works</h2>
            <div class="marquee-container">
                <div class="marquee-content">
                    {
                        [...works, ...works].map((work) => (
                            <a
                                href={work.href}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="marquee-item"
                            >
                                {work.title.en}
                            </a>
                        ))
                    }
                </div>
            </div>
            <div style="text-align: left; margin-top: 1rem;">
                <a href="/en/works/" class="forward-link">
                    View all works
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                            points="12 5 19 12 12 19"></polyline></svg
                    >
                </a>
            </div>
        </section>

        <section
            id="skills"
            class="animate-fade-up delay-4"
            style="margin-bottom: 0; padding: 0 1rem 4rem 1rem;"
        >
            <h2>Skills</h2>
            <div class="skills-group" style="margin-bottom: 1.5rem;">
                <h3
                    style="font-size: 1rem; color: var(--text-muted); margin-bottom: 0.5rem;"
                >
                    Dev & Code
                </h3>
                <div class="tags">
                    {
                        devSkills.map((skill) => (
                            <span
                                class="tag"
                                style={`--tag-color: ${skill.color}; --tag-text: ${skill.textColor};`}
                            >
                                <TechIcon name={getIconName(skill.icon)} />{" "}
                                {skill.name}
                            </span>
                        ))
                    }
                </div>
            </div>
            <div class="skills-group">
                <h3
                    style="font-size: 1rem; color: var(--text-muted); margin-bottom: 0.5rem;"
                >
                    Tools & Others
                </h3>
                <div class="tags">
                    {
                        toolSkills.map((skill) => (
                            <span
                                class="tag"
                                style={`--tag-color: ${skill.color}; --tag-text: ${skill.textColor};`}
                            >
                                <TechIcon name={getIconName(skill.icon)} />{" "}
                                {skill.name}
                            </span>
                        ))
                    }
                </div>
            </div>
        </section>

        <section
            id="about"
            class="animate-fade-up delay-5"
            style="margin-bottom: 4rem; padding: 0 1rem;"
        >
            <h2>About</h2>
            <p style="line-height: 1.8; color: var(--text-color);">
                I graduated from a commercial high school with a focus on
                Information Design and am currently enrolled in The Open
                University of Japan. As a gadget enthusiast who collects
                smartwatches and smartphones, I am passionate about creating
                things through Minecraft modding, bot development, and Chrome
                extensions while exploring new technologies.
            </p>
        </section>

        <script>
            import { setupMarquee } from "../../scripts/marquee";
            import { initGravityEasterEgg } from "../../scripts/gravity";
            import { initTypewriter } from "../../scripts/typewriter";
            import { initGlowEffect } from "../../scripts/glow";

            setupMarquee();
            initGravityEasterEgg();
            initTypewriter();
            initGlowEffect();
        </script>
    </div>
</Layout>
