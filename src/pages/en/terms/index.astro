---
import Layout from "../../../layouts/Layout.astro";
---

<Layout title="Terms of Service | manpuc" lang="en">
    <div class="container">
        <div class="back-nav animate-fade-up">
            <a href="/en/" class="back-link">
                <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><line x1="19" y1="12" x2="5" y2="12"></line><polyline
                        points="12 19 5 12 12 5"></polyline></svg
                >
                Back to Home
            </a>
        </div>

        <header>
            <h1>Terms of Service</h1>
            <p class="subtitle">utilization rules</p>
        </header>

        <div class="neumorph-card">
            <section style="margin-bottom: 2rem;">
                <h2>Article 1 (Applicability)</h2>
