---
import Layout from "../../../layouts/Layout.astro";
import WorkCard from "../../../components/WorkCard.astro";
import { works } from "../../../data/works";

const softwareItems = works.map((work, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
        "@type": "SoftwareApplication",
        "name": work.title.en,
        "description": work.description.en.replace(/<br \/>/g, " "),
        "applicationCategory": work.category || "DeveloperApplication",
        "operatingSystem": work.os || "Cross-platform",
        "url": work.href || `https://manpuc.me/en/works#${work.id}`
    }
}));
---

<Layout
    title="Works Gallery (Minecraft Mod / Discord Bot) - manpuc"
    description="A collection of past projects by manpuc, including Minecraft Forge mods, multi-functional Discord bots, Chrome extensions, and web development."
    lang="en"
    structuredData={[
        {
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Home",
                    "item": "https://manpuc.me/en/",
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "Works",
                    "item": "https://manpuc.me/en/works",
                },
            ],
        },
        {
            "@context": "https://schema.org",
            "@type": "ItemList",
            "name": "Works by manpuc",
            "numberOfItems": works.length,
            "itemListElement": softwareItems
        }
    ]}
>
    <div class="back-nav">
        <a href="/en/" class="back-btn" aria-label="Back to home">
            <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="back-btn-icon"
            >
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>

            <span class="text-long"> Back to home </span>

            <span class="text-short"> Home </span>
        </a>
    </div>

    <div class="container">
        <!-- Header -->
        <header class="reveal" style="animation-delay: 0.1s;">
            <h1>All Works</h1>
            <p class="subtitle">A list of my past works</p>
        </header>

        <!-- All Works Section -->
        <section class="glass-card reveal" style="animation-delay: 0.2s;">
            <div class="works-grid">
                {works.map((work, index) => (
                    <WorkCard 
                        title={work.title.en}
                        description={work.description.en}
                        tags={work.tags}
                        href={work.id === "portfolio" ? "/en/" : work.href}
                        style={`view-transition-name: work-${index + 1}`}
                    />
                ))}
            </div>
        </section>
    </div>
</Layout>

<style>

    /* --- Works specifics (scoping for transitions) --- */
    ::view-transition-group(box-backbtn),
    ::view-transition-group(box-header),
    ::view-transition-group(box-works),
    ::view-transition-group(work-1),
    ::view-transition-group(work-2),
    ::view-transition-group(work-3),
    ::view-transition-group(work-4),
    ::view-transition-group(work-5) {
        animation-duration: 0.4s;
        animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    ::view-transition-old(box-backbtn),
    ::view-transition-old(box-header),
    ::view-transition-old(box-works),
    ::view-transition-old(work-1),
    ::view-transition-old(work-2),
    ::view-transition-old(work-3),
    ::view-transition-old(work-4),
    ::view-transition-old(work-5) {
        display: none;
    }

    ::view-transition-new(box-backbtn),
    ::view-transition-new(box-header),
    ::view-transition-new(box-works),
    ::view-transition-new(work-1),
    ::view-transition-new(work-2),
    ::view-transition-new(work-3),
    ::view-transition-new(work-4),
    ::view-transition-new(work-5) {
        animation: none;
    }
</style>

