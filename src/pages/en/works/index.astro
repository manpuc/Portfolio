---
import Layout from "../../../layouts/Layout.astro";
import { works } from "../../../data/works";
---

<Layout
    title="All Works - manpuc"
    description="List of works by manpuc."
    lang="en"
>
    <div class="container">
        <header>
            <h1>All Works</h1>
            <p class="subtitle">A complete list of my past works.</p>
        </header>

        <div class="back-nav animate-fade-up" style="margin-top: 1rem; margin-bottom: 0.5rem;">
            <a href="/en/" class="back-link" style="margin-bottom: 0;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                Back to Home
            </a>
        </div>

        <section style="margin-top: 1.5rem;">
            <ul class="minimal-works-list">
                {
                    works.map((work, index) => (
                        <li class="minimal-work-item animate-fade-up" style={`animation-delay: ${0.15 + index * 0.08}s`}>
                            {work.href ? (
                                <a href={work.href} target="_blank" rel="noopener noreferrer" class="minimal-work-link">
                                    <span class="minimal-work-title">
                                        {work.title.en}
                                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.5;"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                                    </span>
                                    <span class="minimal-work-desc">{work.description.en}</span>
                                    {work.tags && work.tags.length > 0 && (
                                        <div class="tags" style="margin-top: 0.5rem; gap: 0.35rem;">
                                            {work.tags.map(tag => (
                                                <span class="tag" style="padding: 0.2rem 0.6rem; font-size: 0.75rem;">{tag}</span>
                                            ))}
                                        </div>
                                    )}
                                </a>
                            ) : (
                                <div class="minimal-work-link disabled" style="opacity: 0.7; cursor: default;">
                                    <span class="minimal-work-title">
                                        {work.title.en}
                                    </span>
                                    <span class="minimal-work-desc">{work.description.en}</span>
                                    {work.tags && work.tags.length > 0 && (
                                        <div class="tags" style="margin-top: 0.5rem; gap: 0.35rem;">
                                            {work.tags.map(tag => (
                                                <span class="tag" style="padding: 0.2rem 0.6rem; font-size: 0.75rem;">{tag}</span>
                                            ))}
                                        </div>
                                    )}
                                </div>
                            )}
                        </li>
                    ))
                }
            </ul>
        </section>
    </div>
</Layout>
