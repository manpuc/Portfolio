---
import Layout from "../../layouts/Layout.astro";
import { works } from "../../data/works";
---

<Layout
    title="制作実績一覧 - manpuc"
    description="まんぷく（manpuc）の過去の制作実績一覧。"
    lang="ja"
>
    <div class="container">
        <header>
            <h1>All Works</h1>
            <p class="subtitle">これまでの制作実績一覧</p>
        </header>

        <div class="back-nav animate-fade-up">
            <a href="/" class="back-link" aria-label="ホームに戻る">
                <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    role="img"
                    aria-label="戻るアイコン"
                    ><line x1="19" y1="12" x2="5" y2="12"></line><polyline
                        points="12 19 5 12 12 5"></polyline></svg
                >
                ホームに戻る
            </a>
        </div>

        <section class="works-list-section">
            <ul class="minimal-works-list">
                {
                    works.map((work, index) => (
                        <li
                            class="minimal-work-item animate-fade-up"
                            style={`animation-delay: ${0.1 + index * 0.05}s`}
                        >
                            {work.href ? (
                                <a
                                    href={work.href}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="minimal-work-link"
                                >
                                    <span class="minimal-work-title">
                                        {work.title.ja}
                                        <svg
                                            viewBox="0 0 24 24"
                                            width="16"
                                            height="16"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            class="external-link-icon"
                                            role="img"
                                            aria-label="外部リンク"
                                        >
                                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                                            <polyline points="15 3 21 3 21 9" />
                                            <line
                                                x1="10"
                                                y1="14"
                                                x2="21"
                                                y2="3"
                                            />
                                        </svg>
                                    </span>
                                    <span class="minimal-work-desc">
                                        {work.description.ja}
                                    </span>
                                    {work.tags && work.tags.length > 0 && (
                                        <div
                                            class="tags"
                                            style="margin-top: 0.5rem; gap: 0.35rem;"
                                        >
                                            {work.tags.map((tag) => (
                                                <span
                                                    class="tag"
                                                    style="padding: 0.2rem 0.6rem; font-size: 0.75rem;"
                                                >
                                                    {tag}
                                                </span>
                                            ))}
                                        </div>
                                    )}
                                </a>
                            ) : (
                                <div
                                    class="minimal-work-link disabled"
                                    style="opacity: 0.7; cursor: default;"
                                >
                                    <span class="minimal-work-title">
                                        {work.title.ja}
                                    </span>
                                    <span class="minimal-work-desc">
                                        {work.description.ja}
                                    </span>
                                    {work.tags && work.tags.length > 0 && (
                                        <div class="tags work-item-tags">
                                            {work.tags.map((tag) => (
                                                <span class="tag work-item-tag">
                                                    {tag}
                                                </span>
                                            ))}
                                        </div>
                                    )}
                                </div>
                            )}
                        </li>
                    ))
                }
            </ul>
        </section>
    </div>
</Layout>
