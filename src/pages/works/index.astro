---
import Layout from "../../layouts/Layout.astro";
import WorkCard from "../../components/WorkCard.astro";
import { works } from "../../data/works";

const softwareItems = works.map((work, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
        "@type": "SoftwareApplication",
        "name": work.title.ja,
        "description": work.description.ja.replace(/<br \/>/g, " "),
        "applicationCategory": work.category || "DeveloperApplication",
        "operatingSystem": work.os || "Cross-platform",
        "url": work.href || `https://manpuc.me/works#${work.id}`
    }
}));
---

<Layout
    title="制作実績一覧 (Minecraft Mod / Discord Bot) - manpuc"
    description="まんぷく（manpuc）の過去の制作実績一覧。Minecraft Forge 1.20.1向けMod開発、多機能Discord Bot、Chrome拡張機能、各種Web制作など、実際に配布・運用中のプロダクトを公開しています。"
    lang="ja"
    structuredData={[
        {
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Home",
                    "item": "https://manpuc.me/",
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "Works",
                    "item": "https://manpuc.me/works",
                },
            ],
        },
        {
            "@context": "https://schema.org",
            "@type": "ItemList",
            "name": "Works by manpuc",
            "numberOfItems": works.length,
            "itemListElement": softwareItems
        }
    ]}
>
    <div class="back-nav">
        <a href="/" class="back-btn" aria-label="Back to home">
            <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="back-btn-icon"
            >
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>

            <span class="text-long"> ホームに戻る </span>

            <span class="text-short"> ホーム </span>
        </a>
    </div>

    <div class="container">
        <!-- Header -->
        <header class="reveal" style="animation-delay: 0.1s;">
            <h1>All Works</h1>
            <p class="subtitle">これまでの制作実績一覧</p>
        </header>

        <!-- All Works Section -->
        <section class="reveal" style="animation-delay: 0.2s;">
            <div class="works-grid">
                {works.map((work, index) => (
                    <WorkCard 
                        title={work.title.ja}
                        description={work.description.ja}
                        tags={work.tags}
                        href={work.href}
                        style={`view-transition-name: work-${index + 1}`}
                    />
                ))}
            </div>
        </section>
    </div>
</Layout>

<style>
    /* --- Navigation (Back to Home) --- */
    .back-nav {
        position: fixed;
        top: 30px;
        left: 30px;
        z-index: 1000;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 65px;
        width: 210px;
        padding: 0 28px;
        gap: 10px;
        background: var(--card-bg);
        color: var(--txt-main);
        text-decoration: none;
        border-radius: 50px;
        font-weight: 700;
        border: 1px solid var(--border);
        box-shadow: 0 10px 30px var(--shadow);
        overflow: hidden;
        white-space: nowrap;
        position: relative;
        isolation: isolate;
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
        transition: all 0.4s cubic-bezier(0.65, 0, 0.35, 1);
    }

    /* すりガラス効果：global.css の疑似要素に依存せずスコープ内で直接定義 */
    .back-btn::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: -1;
        border-radius: inherit;
        pointer-events: none;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        filter: url(#glass-distortion);
        -webkit-filter: url(#glass-distortion);
    }

    .back-btn::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 0;
        border-radius: inherit;
        box-shadow: inset 0 0 6px -3px rgba(255, 255, 255, 0.7);
        pointer-events: none;
    }

    .back-btn-icon {
        width: 20px;
        height: 20px;
        flex-shrink: 0;
        transition: all 0.4s cubic-bezier(0.65, 0, 0.35, 1);
    }

    .back-btn:hover {
        background: var(--blu);
        color: #fff;
        transform: scale(1.05);
        border-color: var(--blu);
    }
    .back-btn:active {
        transform: scale(0.95);
    }
    .back-btn svg {
        transition: all 0.6s cubic-bezier(0.65, 0, 0.35, 1);
    }
    .back-btn:hover svg {
        transform: translateX(-4px);
    }

    @media (max-width: 480px) {
        .back-btn {
            width: 140px;
            padding: 0 25px;
        }
    }

    @media (max-width: 360px) {
        .back-btn {
            width: 65px;
            padding: 0;
            gap: 0;
            border-radius: 35px;
        }

        .back-btn-icon {
            width: 24px;
            height: 24px;
        }
        .back-btn svg {
            width: 24px;
            height: 24px;
            margin: 0;
        }
    }

    /* --- Works specifics (scoping for transitions) --- */
    ::view-transition-group(box-backbtn),
    ::view-transition-group(box-header),
    ::view-transition-group(box-works),
    ::view-transition-group(work-1),
    ::view-transition-group(work-2),
    ::view-transition-group(work-3),
    ::view-transition-group(work-4),
    ::view-transition-group(work-5) {
        animation-duration: 0.4s;
        animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    ::view-transition-old(box-backbtn),
    ::view-transition-old(box-header),
    ::view-transition-old(box-works),
    ::view-transition-old(work-1),
    ::view-transition-old(work-2),
    ::view-transition-old(work-3),
    ::view-transition-old(work-4),
    ::view-transition-old(work-5) {
        display: none;
    }

    ::view-transition-new(box-backbtn),
    ::view-transition-new(box-header),
    ::view-transition-new(box-works),
    ::view-transition-new(work-1),
    ::view-transition-new(work-2),
    ::view-transition-new(work-3),
    ::view-transition-new(work-4),
    ::view-transition-new(work-5) {
        animation: none;
    }
</style>

