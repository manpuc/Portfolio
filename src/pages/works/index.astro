---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Works - Kouki Fujikawa">
    <div class="back-nav">
        <a href="/" class="back-btn">
            <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            <span class="txt-ja">ホームに戻る</span><span class="txt-en"
                >Back to Home</span
            >
        </a>
    </div>

    <div class="container">
        <!-- Header -->
        <header class="reveal" style="animation-delay: 0.1s;">
            <h1>All Works</h1>
            <p class="subtitle">
                <span class="txt-ja">これまでの制作実績一覧</span>
                <span class="txt-en">A list of my past works</span>
            </p>
        </header>

        <!-- All Works Section -->
        <section class="reveal" style="animation-delay: 0.2s;">
            <div class="works-grid">
                <!-- Portfolio Site -->
                <a href="/" class="work-item" target="_blank" rel="noopener">
                    <h4>Portfolio Website</h4>
                    <p class="work-desc">
                        <span class="txt-ja"
                            >マイクロインタラクションやUIの心地よさにこだわって制作したポートフォリオサイト。</span
                        >
                        <span class="txt-en"
                            >A portfolio website designed with a focus on
                            micro-interactions and comfortable UI.</span
                        >
                    </p>
                    <div class="tags">
                        <span class="tag">React</span>
                        <span class="tag">Astro</span>
                        <span class="tag">CSS Animation</span>
                    </div>
                </a>

                <!-- Minecraft MOD -->
                <a
                    href="https://modrinth.com/user/manpuc"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h4>Minecraft Mod</h4>
                    <p class="work-desc">
                        <span class="txt-ja"
                            >Forge
                            1.20.1環境での独自Mod開発。新しいアイテムやシステムを実装。</span
                        >
                        <span class="txt-en"
                            >Custom Mod development for Forge 1.20.1.
                            Implemented new items and systems.</span
                        >
                    </p>
                    <div class="tags">
                        <span class="tag">Java</span>
                        <span class="tag">Forge</span>
                    </div>
                </a>

                <!-- Discord BOT -->
                <a
                    href="https://github.com/manpuc/MBot"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h4>Custom Discord Bot</h4>
                    <p class="work-desc">
                        <span class="txt-ja"
                            >サーバー管理やエンタメ機能を備えた多機能汎用Botの開発と運用。</span
                        >
                        <span class="txt-en"
                            >Developed and operated a versatile Discord bot with
                            server management and entertainment features.</span
                        >
                    </p>
                    <div class="tags">
                        <span class="tag">Node.js</span>
                        <span class="tag">API</span>
                    </div>
                </a>

                <!-- Minecraft Bedrock Server -->
                <a href="#" class="work-item" target="_blank" rel="noopener">
                    <h4>Minecraft Server</h4>
                    <p class="work-desc">
                        <span class="txt-ja"
                            >Minecraft Bedrock Editionのサーバーの構築と運用。</span
                        >
                        <span class="txt-en"
                            >Built and managed a Minecraft Bedrock Edition
                            server.</span
                        >
                    </p>
                    <div class="tags">
                        <span class="tag">Minecraft</span>
                        <span class="tag">Server</span>
                        <span class="tag">VPS</span>
                    </div>
                </a>

                <!-- パッケージデザイン -->
                <a href="" class="work-item" target="_blank" rel="noopener">
                    <h4>Package Design</h4>
                    <p class="work-desc">
                        <span class="txt-ja"
                            >「宇摩のやまじ風」のリニューアルデザイン。</span
                        >
                        <span class="txt-en">Package design for products.</span>
                    </p>
                    <div class="tags">
                        <span class="tag">Design</span>
                        <span class="tag">Illustrator</span>
                    </div>
                </a>

                <!-- Chrome Theme -->
                <a
                    href="https://chromewebstore.google.com/detail/ganlcelmnoaidpmaegcmhecolonfmffk?utm_source=item-share-cb"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h4>Chrome Theme</h4>
                    <p class="work-desc">
                        <span class="txt-ja"
                            >目に優しい配色で使いやすいChromeダークテーマ</span
                        >
                        <span class="txt-en"
                            >A user-friendly Chrome dark theme featuring a
                            soothing color palette.</span
                        >
                    </p>
                    <div class="tags">
                        <span class="tag">CSS</span>
                        <span class="tag">JSON</span>
                        <span class="tag">Theme</span>
                    </div>
                </a>

                <!-- Chrome 拡張機能 -->
                <a
                    href="https://chromewebstore.google.com/search/manpuc?hl=ja&authuser=0"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h4>Chrome Extension</h4>
                    <p class="work-desc">
                        <span class="txt-ja"
                            >ブラウザの利便性を向上させるためのカスタム拡張機能の制作。</span
                        >
                        <span class="txt-en"
                            >Created custom extensions to improve browser
                            usability and functionality.</span
                        >
                    </p>
                    <div class="tags">
                        <span class="tag">JavaScript</span>
                        <span class="tag">Web</span>
                        <span class="tag">Extension</span>
                    </div>
                </a>
            </div>
        </section>
    </div>
</Layout>

<style>
    /* --- Navigation (Back to Home) --- */
    .back-nav {
        position: fixed;
        top: 30px;
        left: 30px;
        z-index: 1000;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 65px;
        padding: 0 28px;
        background: var(--card-bg);
        color: var(--txt-main);
        text-decoration: none;
        border-radius: 50px;
        font-weight: 700;
        border: 1px solid var(--border);
        box-shadow: 0 10px 30px var(--shadow);
        transition:
            transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
            background 0.8s ease;
        position: relative;
        isolation: isolate;
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
    }

    .back-btn:hover {
        background: var(--blu);
        color: #fff;
        transform: scale(1.05);
        border-color: var(--blu);
    }

    .back-btn:active {
        transform: scale(0.95);
    }

    .back-btn svg {
        width: 18px;
        height: 18px;
        margin-right: 8px;
        transition: transform 0.3s ease;
    }

    .back-btn:hover svg {
        transform: translateX(-4px);
    }

    /* --- Works specifics --- */
    .work-desc {
        color: var(--txt-sub);
        font-size: 0.9em;
        margin-bottom: 10px;
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .tag {
        font-size: 0.75em;
        padding: 4px 10px;
        background: rgba(0, 0, 0, 0.05);
        border-radius: 50px;
        color: var(--blu);
        font-weight: 700;
        font-family: "JetBrains Mono", monospace;
    }

    body.dark .tag {
        background: rgba(255, 255, 255, 0.05);
    }

    /* View Transitions (hrefが同じだと重複エラーになるので個別に名前を付ける) */
    .work-item:nth-child(1) {
        view-transition-name: work-1;
    }
    .work-item:nth-child(2) {
        view-transition-name: work-2;
    }
    .work-item:nth-child(3) {
        view-transition-name: work-3;
    }
    .work-item:nth-child(4) {
        view-transition-name: work-4;
    }
    .work-item:nth-child(5) {
        view-transition-name: work-5;
    }

    ::view-transition-group(box-backbtn),
    ::view-transition-group(box-header),
    ::view-transition-group(box-works),
    ::view-transition-group(work-1),
    ::view-transition-group(work-2),
    ::view-transition-group(work-3),
    ::view-transition-group(work-4),
    ::view-transition-group(work-5) {
        animation-duration: 0.6s;
        animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    ::view-transition-old(box-backbtn),
    ::view-transition-old(box-header),
    ::view-transition-old(box-works),
    ::view-transition-old(work-1),
    ::view-transition-old(work-2),
    ::view-transition-old(work-3),
    ::view-transition-old(work-4),
    ::view-transition-old(work-5) {
        display: none;
    }

    ::view-transition-new(box-backbtn),
    ::view-transition-new(box-header),
    ::view-transition-new(box-works),
    ::view-transition-new(work-1),
    ::view-transition-new(work-2),
    ::view-transition-new(work-3),
    ::view-transition-new(work-4),
    ::view-transition-new(work-5) {
        animation: none;
    }
</style>
