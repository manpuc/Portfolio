---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
<!DOCTYPE html>
<html lang="ja">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="../../favicon.svg" type="image/svg+xml">
    <title>Works - Kouki Fujikawa</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Zen+Maru+Gothic:wght@400;500;700&display=swap"
        rel="stylesheet">
</head>

<body class="light">
    <!-- SVG Filter -->
    <svg width="0" height="0" style="position: absolute;">
        <defs>
            <filter id="glass-distortion" x="0%" y="0%" width="100%" height="100%">
                <feTurbulence type="fractalNoise" baseFrequency="0.006 0.006" numOctaves="2" seed="92" result="noise" />
                <feGaussianBlur in="noise" stdDeviation="2" result="blurred" />
                <feDisplacementMap in="SourceGraphic" in2="blurred" scale="65" xChannelSelector="R"
                    yChannelSelector="G" />
            </filter>
        </defs>
    </svg>

    <div class="bg-blob"></div>
    <div class="bg-blob2"></div>
    <div class="bg-blob3"></div>

    <div class="bg-particles">
        <div class="particle p-1"></div>
        <div class="particle p-2"></div>
        <div class="particle p-3"></div>
        <div class="particle p-4"></div>
        <div class="particle p-5"></div>
    </div>

    <!-- 言語切り替えトグル -->
    <button class="theme-toggle" id="langToggle" aria-label="Toggle Language" style="right: 110px;">
        <div class="icon-container">
            <svg class="lang-icon-en" viewBox="0 0 24 24">
                <text x="50%" y="54%" dominant-baseline="middle" text-anchor="middle" fill="currentColor"
                    font-family="'JetBrains Mono', monospace" font-weight="700" font-size="11"
                    letter-spacing="0.5px">EN</text>
            </svg>
            <svg class="lang-icon-ja" viewBox="0 0 24 24">
                <text x="50%" y="54%" dominant-baseline="middle" text-anchor="middle" fill="currentColor"
                    font-family="'JetBrains Mono', monospace" font-weight="700" font-size="11"
                    letter-spacing="0.5px">JA</text>
            </svg>
        </div>
    </button>

    <!-- Theme Toggle -->
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle Theme">
        <div class="icon-container">
            <svg class="sun-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"></circle>
                <line x1="12" y1="1" x2="12" y2="3"></line>
                <line x1="12" y1="21" x2="12" y2="23"></line>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                <line x1="1" y1="12" x2="3" y2="12"></line>
                <line x1="21" y1="12" x2="23" y2="12"></line>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg class="moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
        </div>
    </button>

    <!-- Back Navigation -->
    <div class="back-nav">
        <a href="/" class="back-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            <span class="txt-ja">ホームに戻る</span><span class="txt-en">Back to Home</span>
        </a>
    </div>

    <!-- Contact Btn-->
    <a href="/#contact" class="contact-fab" aria-label="Go to Contact">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
            stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
    </a>

    <div class="container">

        <!-- Header -->
        <header class="reveal" style="animation-delay: 0.1s;">
            <h1>All Works</h1>
            <p class="subtitle">
                <span class="txt-ja">これまでの制作実績一覧</span>
                <span class="txt-en">A list of my past works</span>
            </p>
        </header>

        <!-- All Works Section -->
        <section class="reveal" style="animation-delay: 0.2s;">
            <div class="works-grid">
                <!-- Portfolio Site -->
                <a href="/" class="work-item" target="_blank" rel="noopener">
                    <h4>Portfolio Website</h4>
                    <p class="work-desc">
                        <span class="txt-ja">マイクロインタラクションやUIの心地よさにこだわって制作したポートフォリオサイト。</span>
                        <span class="txt-en">A portfolio website designed with a focus on micro-interactions and
                            comfortable UI.</span>
                    </p>
                    <div class="tags">
                        <span class="tag">HTML</span>
                        <span class="tag">Vanilla JS</span>
                        <span class="tag">CSS Animation</span>
                    </div>
                </a>

                <!-- Minecraft MOD -->
                <a href="https://modrinth.com/user/manpuc" class="work-item" target="_blank" rel="noopener">
                    <h4>Minecraft Mod</h4>
                    <p class="work-desc">
                        <span class="txt-ja">Forge 1.20.1環境での独自Mod開発。新しいアイテムやシステムを実装。</span>
                        <span class="txt-en">Custom Mod development for Forge 1.20.1. Implemented new items and
                            systems.</span>
                    </p>
                    <div class="tags">
                        <span class="tag">Java</span>
                        <span class="tag">Forge</span>
                    </div>
                </a>

                <!-- Discord BOT -->
                <a href="https://github.com/manpuc/MBot" class="work-item" target="_blank" rel="noopener">
                    <h4>Custom Discord Bot</h4>
                    <p class="work-desc">
                        <span class="txt-ja">サーバー管理やエンタメ機能を備えた多機能汎用Botの開発と運用。</span>
                        <span class="txt-en">Developed and operated a versatile Discord bot with server management and
                            entertainment features.</span>
                    </p>
                    <div class="tags">
                        <span class="tag">Python</span>
                        <span class="tag">API</span>
                    </div>
                </a>

                <!-- パッケージデザイン -->
                <a href="#" class="work-item" target="_blank" rel="noopener">
                    <h4>Package Design</h4>
                    <p class="work-desc">
                        <span class="txt-ja">「」のパッケージデザイン。</span>
                        <span class="txt-en">Package design for products.</span>
                    </p>
                    <div class="tags">
                        <span class="tag">Design</span>
                        <span class="tag">Illustrator</span>
                    </div>
                </a>

                <!-- Chrome 拡張機能 -->
                <a href="#" class="work-item" target="_blank" rel="noopener">
                    <h4>Chrome Extension</h4>
                    <p class="work-desc">
                        <span class="txt-ja">ブラウザの利便性を向上させるためのカスタム拡張機能の制作。</span>
                        <span class="txt-en">Created custom extensions to improve browser usability and
                            functionality.</span>
                    </p>
                    <div class="tags">
                        <span class="tag">JavaScript</span>
                        <span class="tag">Web</span>
                    </div>
                </a>
            </div>
        </section>
    </div>
    <!-- Footer -->
    <footer class="site-footer">
        <div class="footer-content">
            <div class="footer-logo">
                <img src="../avatar.png" alt="Kouki Fujikawa" class="footer-avatar" oncontextmenu="return false;">
                <div class="footer-title">
                    <h3>Kouki Fujikawa</h3>
                    <p class="txt-ja">学生・デベロッパー・クリエイター</p>
                    <p class="txt-en">Student / Developer / Creator</p>
                </div>
            </div>

            <div class="footer-right">
                <div class="footer-nav">
                    <a href="../#about"><span class="txt-ja">概要</span><span class="txt-en">About</span></a>
                    <a href="../#skills"><span class="txt-ja">スキル</span><span class="txt-en">Skills</span></a>
                    <a href="../#works"><span class="txt-ja">実績</span><span class="txt-en">Works</span></a>
                    <a href="../#contact"><span class="txt-ja">お問い合わせ</span><span class="txt-en">Contact</span></a>
                </div>

                <div class="footer-socials">
                    <a href="mailto:info@manpuc.me" aria-label="Email" class="social-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                            stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z">
                            </path>
                            <polyline points="22,6 12,13 2,6"></polyline>
                        </svg>
                    </a>
                    <a href="https://github.com/manpuc" target="_blank" rel="noopener noreferrer" aria-label="GitHub"
                        class="social-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                            stroke-linecap="round" stroke-linejoin="round">
                            <path
                                d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22">
                            </path>
                        </svg>
                    </a>
                    <a href="https://twitter.com/manpuccc" target="_blank" rel="noopener noreferrer"
                        aria-label="Twitter" class="social-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                            stroke-linecap="round" stroke-linejoin="round">
                            <path
                                d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z">
                            </path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 Kouki Fujikawa. All Rights Reserved.</p>
        </div>
    </footer>
    <script>
        const langToggleBtn = document.getElementById('langToggle');
        const savedLang = localStorage.getItem('portfolio-lang');

        if (savedLang === 'en') {
            document.body.classList.add('en-mode');
            document.documentElement.lang = 'en';
        }

        langToggleBtn.addEventListener('click', () => {
            const switchLang = () => {
                document.body.classList.toggle('en-mode');
                if (document.body.classList.contains('en-mode')) {
                    localStorage.setItem('portfolio-lang', 'en');
                    document.documentElement.lang = 'en';
                } else {
                    localStorage.setItem('portfolio-lang', 'ja');
                    document.documentElement.lang = 'ja';
                }
            };

            if (document.startViewTransition) {
                document.startViewTransition(switchLang);
            } else {
                switchLang();
            }
        });

        const toggleBtn = document.getElementById('themeToggle');
        const body = document.body;

        const savedTheme = localStorage.getItem('portfolio-theme');
        const osDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

        if (savedTheme === 'dark' || (!savedTheme && osDark)) {
            body.classList.add('dark');
            body.classList.remove('light');
        }

        toggleBtn.addEventListener('click', () => {
            if (body.classList.contains('dark')) {
                body.classList.remove('dark');
                body.classList.add('light');
                localStorage.setItem('portfolio-theme', 'light');
            } else {
                body.classList.remove('light');
                body.classList.add('dark');
                localStorage.setItem('portfolio-theme', 'dark');
            }
        });
    </script>
</body>

</html>
</Layout>

<style>
    /* --- Tokyo Night Theme Variables --- */
    :root {
        --bg-main: #e6e7ed;
        --bg-sub: #D6D8DF;
        --red: #F52A65;
        --grn: #587539;
        --yel: #8C6C3E;
        --blu: #2E7DE9;
        --purp: #9854F1;
        --cyan: #007197;
        --txt-main: #3760BF;
        --txt-sub: #6172B0;
        --border: rgba(0, 0, 0, 0.08);
        --shadow: rgba(0, 0, 0, 0.1);
        --card-bg: rgba(255, 255, 255, 0.6);
        view-transition-name: none;
    }

    body.dark {
        --bg-main: #1a1b26;
        --bg-sub: #16161e;
        --red: #f7768e;
        --grn: #9ece6a;
        --yel: #E0AF68;
        --blu: #7AA2F6;
        --purp: #BB9AF7;
        --cyan: #7DCFFF;
        --txt-main: #C0CAF5;
        --txt-sub: #A9B1D6;
        --border: rgba(255, 255, 255, 0.06);
        --shadow: rgba(0, 0, 0, 0.4);
        --card-bg: rgba(22, 22, 30, 0.6);
    }

    /* --- Base Setup --- */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        font-family: 'Zen Maru Gothic', 'JetBrains Mono', sans-serif;
        line-height: 1.6;
        color: var(--txt-main);
        background-color: var(--bg-main);
        transition: background-color 0.8s ease, color 0.8s ease;
        overflow-x: hidden;
        position: relative;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    .container {
        max-width: 720px;
        margin: 0 auto;
        padding: 40px 20px;
        position: relative;
        z-index: 1;
        flex: 1 0 auto;
        /*min-height: calc(100vh + 1px);*/
    }

    .site-footer {
        margin-top: auto;
        padding: 40px 20px 20px;
        background: var(--card-bg);
        border-top: 1px solid var(--border);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        box-shadow: 0 -10px 40px var(--shadow);
        position: relative;
        z-index: 10;
    }

    /* --- Orbs --- */
    .bg-blob,
    .bg-blob2,
    .bg-blob3 {
        position: fixed;
        width: 50vw;
        height: 50vw;
        filter: blur(60px);
        z-index: 0;
        pointer-events: none;
        opacity: 0.25 !important;
        mix-blend-mode: multiply;
        transition: opacity 0.8s ease, mix-blend-mode 0.8s ease;
    }

    .bg-blob {
        top: -10%;
        right: -10%;
        background: radial-gradient(circle, var(--purp) 0%, transparent 60%);
        animation: float 12s infinite ease-in-out alternate;
    }

    .bg-blob2 {
        bottom: -10%;
        left: -10%;
        background: radial-gradient(circle, var(--blu) 0%, transparent 60%);
        animation: float 15s infinite ease-in-out alternate-reverse;
    }

    .bg-blob3 {
        top: -5%;
        left: -10%;
        width: 45vw;
        height: 45vw;
        background: radial-gradient(circle, var(--cyan) 0%, transparent 60%);
        animation: float 14s infinite ease-in-out alternate;
    }

    body.dark .bg-blob,
    body.dark .bg-blob2,
    body.dark .bg-blob3 {
        opacity: 0.10 !important;
        mix-blend-mode: screen;
    }

    @keyframes float {
        0% {
            transform: translate(0, 0) scale(1);
        }

        100% {
            transform: translate(30px, 50px) scale(1.1);
        }
    }

    /* --- Background Particles for Glass Distortion --- */
    .bg-particles {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 0;
        pointer-events: none;
        overflow: hidden;
    }

    .particle {
        position: absolute;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--purp), var(--cyan));
        opacity: 0.20;
        filter: blur(8px);
        animation: drift infinite linear alternate;
    }

    body.dark .particle {
        opacity: 0.12;
        background: linear-gradient(135deg, var(--blu), var(--purp));
    }

    .p-1 {
        width: 150px;
        height: 150px;
        top: 20%;
        left: 10%;
        animation-duration: 25s;
    }

    .p-2 {
        width: 250px;
        height: 250px;
        top: 60%;
        left: 80%;
        animation-duration: 35s;
        animation-direction: alternate-reverse;
    }

    .p-3 {
        width: 100px;
        height: 100px;
        top: 80%;
        left: 30%;
        animation-duration: 20s;
    }

    .p-4 {
        width: 300px;
        height: 300px;
        top: 10%;
        left: 60%;
        animation-duration: 40s;
        background: linear-gradient(135deg, var(--yel), var(--red));
        opacity: 0.05;
    }

    .p-5 {
        width: 120px;
        height: 120px;
        top: 40%;
        left: 40%;
        animation-duration: 30s;
        animation-direction: alternate-reverse;
    }

    @keyframes drift {
        0% {
            transform: translate(0, 0) rotate(0deg) scale(1);
        }

        100% {
            transform: translate(150px, -150px) rotate(180deg) scale(1.2);
        }
    }

    /* --- Navigation (Back to Home) --- */
    .back-nav {
        position: fixed;
        top: 30px;
        left: 30px;
        z-index: 1000;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 65px;
        padding: 0 28px;
        background: var(--card-bg);
        color: var(--txt-main);
        text-decoration: none;
        border-radius: 50px;
        font-weight: 700;
        border: 1px solid var(--border);
        box-shadow: 0 10px 30px var(--shadow);
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.8s ease;
        position: relative;
        isolation: isolate;
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
        view-transition-name: box-backbtn;
    }

    .back-btn:hover {
        background: var(--blu);
        color: #fff;
        transform: scale(1.05);
        border-color: var(--blu);
    }

    .back-btn:active {
        transform: scale(0.95);
    }

    .back-btn svg {
        width: 18px;
        height: 18px;
        margin-right: 8px;
        transition: transform 0.3s ease;
    }

    .back-btn:hover svg {
        transform: translateX(-4px);
    }

    /* --- Theme & Lang Toggle --- */
    .theme-toggle {
        position: fixed;
        top: 30px;
        right: 30px;
        width: 65px;
        height: 65px;
        border-radius: 50%;
        background: var(--card-bg);
        border: 1px solid var(--border);
        cursor: pointer;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 30px var(--shadow);
        backdrop-filter: blur(10px);
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.8s ease;
        overflow: hidden;
    }

    .theme-toggle:hover {
        transform: scale(1.15);
    }

    .theme-toggle:active {
        transform: scale(0.9);
    }

    .icon-container {
        position: relative;
        width: 26px;
        height: 26px;
    }

    .sun-icon,
    .moon-icon {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .sun-icon {
        transform: translateY(0) rotate(0deg);
        opacity: 1;
        color: var(--yel);
    }

    .moon-icon {
        transform: translateY(40px) rotate(-90deg);
        opacity: 0;
        color: var(--purp);
    }

    body.dark .sun-icon {
        transform: translateY(-40px) rotate(90deg);
        opacity: 0;
    }

    body.dark .moon-icon {
        transform: translateY(0) rotate(0deg);
        opacity: 1;
    }

    /* --- 言語切り替えトグルアイコン --- */
    .lang-icon-ja,
    .lang-icon-en {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .lang-icon-en {
        transform: translateY(0) rotate(0deg);
        opacity: 1;
        color: var(--cyan);
    }

    .lang-icon-ja {
        transform: translateY(-40px) rotate(90deg);
        opacity: 0;
        color: var(--red);
    }

    body.en-mode .lang-icon-en {
        transform: translateY(40px) rotate(-90deg);
        opacity: 0;
    }

    body.en-mode .lang-icon-ja {
        transform: translateY(0) rotate(0deg);
        opacity: 1;
    }

    /* --- Contact FAB --- */
    .contact-fab {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 65px;
        height: 65px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--purp), var(--blu));
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 25px rgba(152, 84, 241, 0.4);
        z-index: 999;
        text-decoration: none;
        transition: all 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    }

    .contact-fab svg {
        width: 26px;
        height: 26px;
        transition: transform 0.3s ease;
    }

    .contact-fab:hover {
        transform: translateY(-5px) scale(1.1);
        box-shadow: 0 15px 35px rgba(152, 84, 241, 0.6);
    }

    .contact-fab:hover svg {
        transform: scale(1.1);
    }

    /* --- Header --- */
    header {
        text-align: center;
        margin-bottom: 50px;
        padding-top: 50px;
        view-transition-name: box-header;
    }

    h1 {
        font-size: 2.5em;
        color: var(--txt-main);
        margin-bottom: 5px;
        font-weight: 700;
    }

    .subtitle {
        font-size: 1.1em;
        color: var(--purp);
        font-family: 'JetBrains Mono', monospace;
    }

    /* --- Works Section & Grid --- */
    section {
