---
import Layout from "../../layouts/Layout.astro";
---

<Layout
    title="Works - manpuc"
    description="まんぷく（manpuc）の制作実績一覧。Minecraft Mod開発・Discord Bot・Chrome拡張機能・Webサイト制作など。 / A list of works by manpuc: Minecraft Mod, Discord Bot, Chrome Extension, Web Development."
    lang="ja"
    structuredData={{
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
            {
                "@type": "ListItem",
                position: 1,
                name: "Home",
                item: "https://manpuc.me/",
            },
            {
                "@type": "ListItem",
                position: 2,
                name: "Works",
                item: "https://manpuc.me/works",
            },
        ],
    }}
>
    <div class="back-nav">
        <a href="/" class="back-btn" aria-label="Back to home">
            <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="back-btn-icon"
            >
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>

            <span class="text-long"> ホームに戻る </span>

            <span class="text-short"> ホーム </span>
        </a>
    </div>

    <div class="container">
        <!-- Header -->
        <header class="reveal" style="animation-delay: 0.1s;">
            <h1>All Works</h1>
            <p class="subtitle">これまでの制作実績一覧</p>
        </header>

        <!-- All Works Section -->
        <section class="reveal" style="animation-delay: 0.2s;">
            <div class="works-grid">
                <!-- Portfolio Site -->
                <a href="/" class="work-item" target="_blank" rel="noopener">
                    <h3>Portfolio Website</h3>
                    <p class="work-desc">
                        マイクロインタラクションやUIの心地よさにこだわって制作したポートフォリオサイト。
                    </p>
                    <div class="tags">
                        <span class="tag">TypeScript</span>
                        <span class="tag">Astro</span>
                        <span class="tag">CSS</span>
                    </div>
                </a>

                <!-- Minecraft MOD -->
                <a
                    href="https://modrinth.com/user/manpuc"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h3>Minecraft Mod</h3>
                    <p class="work-desc">
                        Forge 1.20.1環境での独自Mod開発<br />
                        新しいアイテムやシステムを実装。
                    </p>
                    <div class="tags">
                        <span class="tag">Java</span>
                        <span class="tag">Forge</span>
                        <span class="tag">Minecraft</span>
                    </div>
                </a>

                <!-- Discord BOT -->
                <a
                    href="https://github.com/manpuc/MBot"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h3>Custom Discord Bot</h3>
                    <p class="work-desc">
                        サーバー管理やエンタメ機能を備えた多機能汎用Botの開発と運用。
                    </p>
                    <div class="tags">
                        <span class="tag">Node.js</span>
                        <span class="tag">API</span>
                    </div>
                </a>

                <!-- ポモドーロタイマー -->
                <a
                    href="https://pomodoro.manpuc.me/"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h3>Pomodoro Timer</h3>
                    <p class="work-desc">
                        タスク、統計機能付きのポモドーロ<br />タイマー。
                    </p>
                    <div class="tags">
                        <span class="tag">TypeScript</span>
                        <span class="tag">Astro</span>
                    </div>
                </a>

                <!-- QRメーカー -->
                <a
                    href="https://qr.manpuc.me/"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h3>QR Maker</h3>
                    <p class="work-desc">
                        使いやすさとカスタム性にこだわったQRコード生成サービス。
                    </p>
                    <div class="tags">
                        <span class="tag">PWA</span>
                        <span class="tag">Astro</span>
                        <span class="tag">TypeScript</span>
                    </div>
                </a>

                <!-- 時計アプリ -->
                <a
                    href="https://ambient.manpuc.me/"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h3>Ambient Clock</h3>
                    <p class="work-desc">
                        ミニマルで美しいデジタル時計アプリ。
                    </p>
                    <div class="tags">
                        <span class="tag">API</span>
                        <span class="tag">PWA</span>
                        <span class="tag">TypeScript</span>
                    </div>
                </a>

                <!-- テキスト変換 -->
                <a
                    href="https://text.manpuc.me/"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h3>Text Flow</h3>
                    <p class="work-desc">
                        汎用性と操作性にこだわったテキスト変換サービス。
                    </p>
                    <div class="tags">
                        <span class="tag">Astro</span>
                        <span class="tag">TypeScript</span>
                    </div>
                </a>

                <!-- Chrome Theme -->
                <a
                    href="https://chromewebstore.google.com/detail/ganlcelmnoaidpmaegcmhecolonfmffk?utm_source=item-share-cb"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h3>Chrome Theme</h3>
                    <p class="work-desc">
                        目に優しい配色で使いやすいChromeダークテーマ
                    </p>
                    <div class="tags">
                        <span class="tag">CSS</span>
                        <span class="tag">JSON</span>
                        <span class="tag">Theme</span>
                    </div>
                </a>

                <!-- Chrome 拡張機能 -->
                <a
                    href="https://chromewebstore.google.com/detail/bdlpogibdkglpceadpplahmjneanbpom?utm_source=item-share-cb"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h3>Google Search Night Theme</h3>
                    <p class="work-desc">
                        Google検索を目に優しいダークテーマに変更する拡張機能。
                    </p>
                    <div class="tags">
                        <span class="tag">Chrome Extension</span>
                        <span class="tag">CSS</span>
                    </div>
                </a>

                <!-- Chrome 拡張機能 -->
                <a
                    href="https://chromewebstore.google.com/detail/diogckmiabncebebknnoibjapaldcjgb?utm_source=item-share-cb"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h3>No Curseforge Legacy</h3>
                    <p class="work-desc">
                        旧デザインのCurseForgeを新デザインURLにリダイレクトする拡張機能。
                    </p>
                    <div class="tags">
                        <span class="tag">Chrome Extension</span>
                        <span class="tag">JavaScript</span>
                    </div>
                </a>

                <!-- Minecraft Bedrock Server -->
                <div class="work-item no-link">
                    <h3>Minecraft Server</h3>
                    <p class="work-desc">
                        Minecraft Bedrock Editionのサーバーの構築と運用。
                    </p>
                    <div class="tags">
                        <span class="tag">Minecraft</span>
                        <span class="tag">Server</span>
                        <span class="tag">VPS</span>
                    </div>
                </div>

                <!-- パッケージデザイン -->
                <div class="work-item no-link">
                    <h3>Package Design</h3>
                    <p class="work-desc">
                        「宇摩のやまじ風」のリニューアルデザイン。
                    </p>
                    <div class="tags">
                        <span class="tag">Design</span>
                        <span class="tag">Illustrator</span>
                    </div>
                </div>
            </div>
        </section>
    </div>
</Layout>

<style>
    /* --- Navigation (Back to Home) --- */
    .back-nav {
        position: fixed;
        top: 30px;
        left: 30px;
        z-index: 1000;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 65px;
        width: 210px;
        padding: 0 28px;
        gap: 10px;
        background: var(--card-bg);
        color: var(--txt-main);
        text-decoration: none;
        border-radius: 50px;
        font-weight: 700;
        border: 1px solid var(--border);
        box-shadow: 0 10px 30px var(--shadow);
        overflow: hidden;
        white-space: nowrap;
        position: relative;
        isolation: isolate;
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
        transition: all 0.4s cubic-bezier(0.65, 0, 0.35, 1);
    }

    /* すりガラス効果：global.css の疑似要素に依存せずスコープ内で直接定義 */
    .back-btn::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: -1;
        border-radius: inherit;
        pointer-events: none;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        filter: url(#glass-distortion);
        -webkit-filter: url(#glass-distortion);
    }

    .back-btn::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 0;
        border-radius: inherit;
        box-shadow: inset 0 0 6px -3px rgba(255, 255, 255, 0.7);
        pointer-events: none;
    }

    .back-btn-icon {
        width: 20px;
        height: 20px;
        flex-shrink: 0;
        transition: all 0.4s cubic-bezier(0.65, 0, 0.35, 1);
    }

    .back-btn:hover {
        background: var(--blu);
        color: #fff;
        transform: scale(1.05);
        border-color: var(--blu);
    }
    .back-btn:active {
        transform: scale(0.95);
    }
    .back-btn svg {
        transition: all 0.6s cubic-bezier(0.65, 0, 0.35, 1);
    }
    .back-btn:hover svg {
        transform: translateX(-4px);
    }

    @media (max-width: 480px) {
        .back-btn {
            width: 140px;
            padding: 0 25px;
        }
    }

    @media (max-width: 360px) {
        .back-btn {
            width: 65px;
            padding: 0;
            gap: 0;
            border-radius: 35px;
        }

        .back-btn-icon {
            width: 24px;
            height: 24px;
        }
        .back-btn svg {
            width: 24px;
            height: 24px;
            margin: 0;
        }
    }

    /* --- Works specifics (scoping for transitions) --- */
    .work-item:nth-child(1) {
        view-transition-name: work-1;
    }
    .work-item:nth-child(2) {
        view-transition-name: work-2;
    }
    .work-item:nth-child(3) {
        view-transition-name: work-3;
    }
    .work-item:nth-child(4) {
        view-transition-name: work-4;
    }
    .work-item:nth-child(5) {
        view-transition-name: work-5;
    }

    ::view-transition-group(box-backbtn),
    ::view-transition-group(box-header),
    ::view-transition-group(box-works),
    ::view-transition-group(work-1),
    ::view-transition-group(work-2),
    ::view-transition-group(work-3),
    ::view-transition-group(work-4),
    ::view-transition-group(work-5) {
        animation-duration: 0.4s;
        animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    ::view-transition-old(box-backbtn),
    ::view-transition-old(box-header),
    ::view-transition-old(box-works),
    ::view-transition-old(work-1),
    ::view-transition-old(work-2),
    ::view-transition-old(work-3),
    ::view-transition-old(work-4),
    ::view-transition-old(work-5) {
        display: none;
    }

    ::view-transition-new(box-backbtn),
    ::view-transition-new(box-header),
    ::view-transition-new(box-works),
    ::view-transition-new(work-1),
    ::view-transition-new(work-2),
    ::view-transition-new(work-3),
    ::view-transition-new(work-4),
    ::view-transition-new(work-5) {
        animation: none;
    }
</style>
