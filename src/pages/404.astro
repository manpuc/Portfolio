---
import Layout from "../layouts/Layout.astro";
import ErrorPage from "../components/ErrorPage.astro";
---

<Layout title="404 Not Found | manpuc" isErrorPage={true}>
  <ErrorPage
    code={404}
    titleJa="ページが見つかりません"
    titleEn="Page Not Found"
    descJa="アクセスしようとしたページは削除されたか、<br />URLが変更されている可能性があります。"
    descEn="The page you are looking for might have been removed<br />or is temporarily unavailable."
    gradient="linear-gradient(135deg, var(--purp), var(--blu))"
  />
</Layout>
