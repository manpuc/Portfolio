---
import Layout from "../layouts/Layout.astro";
import "@fontsource/bungee";
---

<Layout title="404 Not Found | Kouki Fujikawa" isErrorPage={true}>
    <style>
        .error-page-container h2::before {
            background: var(--red) !important;
        }

        .error-code {
            font-family: "Bungee", sans-serif;
            font-size: clamp(5em, 15vw, 8em);
            background: linear-gradient(135deg, var(--purp), var(--blu));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0;
            line-height: 1.1;
        }

        .error-box {
            max-width: 800px;
            margin: 0 auto;
            width: 100%;
        }

        @media (max-width: 860px) {
            .error-page-wrapper {
                padding-top: 125px;
            }

            .error-desc br {
                display: none;
            }
        }
    </style>

    <div
        class="container error-page-container error-page-wrapper"
        style="display: flex; flex-direction: column; justify-content: center; min-height: 70vh;"
    >
        <section
            class="reveal error-box"
            style="text-align: center; padding: 60px 20px;"
        >
            <h1 class="error-code">404</h1>
            <h2
                style="justify-content: center; margin-top: 10px; margin-bottom: 20px; font-size: 1.5em; border: none;"
            >
                <span class="txt-ja">ページが見つかりません</span>
                <span class="txt-en">Page Not Found</span>
            </h2>
            <p
                class="error-desc"
                style="color: var(--txt-sub); margin-bottom: 40px; font-weight: 500; line-height: 1.8;"
            >
                <span class="txt-ja">
                    アクセスしようとしたページは削除されたか、<br />
                    URLが変更されている可能性があります。
                </span>
                <span class="txt-en">
                    The page you are looking for might have been removed<br />
                    or is temporarily unavailable.
                </span>
            </p>

            <div style="display: flex; justify-content: center;">
                <a href="/" class="btn-view-more">
                    <span class="txt-ja">ホームに戻る</span>
                    <span class="txt-en">Back to Home</span>
                </a>
            </div>
        </section>
    </div>
</Layout>
