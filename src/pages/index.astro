---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kouki Fujikawa - Portfolio">
    <div class="container">
        <!-- Header -->
        <header class="reveal">
            <img
                src="/avatar.svg"
                alt="Kouki Fujikawa"
                class="profile-img"
                oncontextmenu="return false;"
            />
            <h1>Kouki Fujikawa</h1>
            <p class="subtitle">@MANPUC / Developer & Creator</p>
        </header>

        <!-- Navigation -->
        <nav class="reveal" style="transition-delay: 0.1s;">
            <a href="#about">About</a>
            <a href="#skills">Skills</a>
            <a href="#works">Works</a>
            <a href="#contact">Contact</a>
        </nav>

        <!-- About Section -->
        <section id="about" class="reveal" style="transition-delay: 0.2s;">
            <h2>About</h2>
            <div class="profile-text">
                <ul>
                    <li>
                        <span class="txt-ja"
                            >高校商業科情報デザイン類型卒業 /
                            放送大学教養学部社会と産業コース入学予定</span
                        ><span class="txt-en"
                            >Graduated from Commercial High School (Information
                            Design) / Entering The Open University of Japan</span
                        >
                    </li>
                    <li>
                        <span class="txt-ja"
                            >ガジェット収集家（スマートウォッチ, スマホ,
                            イヤホン・ヘッドホン など）</span
                        ><span class="txt-en"
                            >Gadget collector (Smartwatches, Smartphones,
                            Earphones, etc.)</span
                        >
                    </li>
                    <li>
                        <span class="txt-ja"
                            >Minecraft Mod開発
                            (Java/Forge)、Bot制作、Chrome拡張機能制作</span
                        ><span class="txt-en"
                            >Minecraft Modding (Java/Forge), Bot Development,
                            Chrome Extensions</span
                        >
                    </li>
                    <li>
                        <span class="txt-ja"
                            >新しい技術やモノづくりが大好きです</span
                        ><span class="txt-en"
                            >I love new technologies and creating things</span
                        >
                    </li>
                </ul>
            </div>
        </section>

        <!-- Skills Section -->
        <section id="skills" class="reveal">
            <h2>Skills</h2>
            <div class="skills-grid">
                <div class="skill-item">
                    <h4>Dev & Code</h4>
                    <ul>
                        <li>Java (Minecraft Forge 1.20.1)</li>
                        <li>JavaScript, Python</li>
                        <li>PowerShell, Batch Scripting</li>
                    </ul>
                </div>
                <div class="skill-item">
                    <h4>Web Development</h4>
                    <ul>
                        <li>HTML / CSS / JavaScript</li>
                        <li>Astro, React, Node.js</li>
                        <li>UI/UX & Modern Animations</li>
                    </ul>
                </div>
                <div class="skill-item">
                    <h4>Tools & Others</h4>
                    <ul>
                        <li>Git, GitHub, pnpm</li>
                        <li>Generative AI Tools</li>
                        <li>
                            <span class="txt-ja">After Effects（動画編集）</span
                            >
                            <span class="txt-en">After Effects</span>
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- Works Section -->
        <section id="works" class="reveal">
            <h2>Works</h2>
            <div class="works-grid">
                <a href="/" class="work-item" target="_blank" rel="noopener">
                    <h4 style="margin-bottom: 5px;">
                        Portfolio Website<span
                            style="font-size: 12px; color: var(--txt-sub);padding-left: 6px;"
                            >This Site</span
                        >
                    </h4>
                    <p style="color: var(--txt-sub); font-size: 0.9em;">
                        <span class="txt-ja"
                            >UIの心地よさにこだわったサイト</span
                        >
                        <span class="txt-en"
                            >A website focusing on a comfortable UI</span
                        >
                    </p>
                </a>
                <a
                    href="https://modrinth.com/user/manpuc"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h4 style="margin-bottom: 5px;">Minecraft Mod</h4>
                    <p style="color: var(--txt-sub); font-size: 0.9em;">
                        <span class="txt-ja"
                            >Forge 1.20.1環境での独自Mod開発。</span
                        >
                        <span class="txt-en"
                            >Custom Mod development for Forge.</span
                        >
                    </p>
                </a>
                <a
                    href="https://github.com/manpuc/MBot"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h4 style="margin-bottom: 5px;">Custom Discord Bot</h4>
                    <p style="color: var(--txt-sub); font-size: 0.9em;">
                        <span class="txt-ja">守備範囲の広い多機能汎用Bot。</span
                        >
                        <span class="txt-en">Multi-functional Discord Bot.</span
                        >
                    </p>
                </a>
                <a
                    href="https://chromewebstore.google.com/detail/ganlcelmnoaidpmaegcmhecolonfmffk?utm_source=item-share-cb"
                    class="work-item"
                    target="_blank"
                    rel="noopener"
                >
                    <h4 style="margin-bottom: 5px;">Chrome Theme</h4>
                    <p style="color: var(--txt-sub); font-size: 0.9em;">
                        <span class="txt-ja">目に優しいChromeダークテーマ</span>
                        <span class="txt-en"
                            >An eye-friendly Chrome dark theme</span
                        >
                    </p>
                </a>
            </div>

            <div class="view-more-container">
                <a href="/works/" class="btn-view-more">
                    <span class="txt-ja">すべて</span>
                    <span class="txt-en">View All</span>
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        style="width: 20px; height: 20px;"
                    >
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </a>
            </div>
        </section>

        <!-- Contact Section -->
        <section id="contact" class="reveal">
            <h2>Contact</h2>
            <div class="contact-links">
                <a href="mailto:info@manpuc.me" class="btn-email">
                    <svg
                        class="contact-icon email-icon"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                        ></path>
                        <polyline points="22,6 12,13 2,6"></polyline>
                    </svg>
                    Email
                </a>
                <a
                    href="https://github.com/manpuc"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-github"
                >
                    <svg
                        class="contact-icon github-icon"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
                        ></path>
                    </svg>
                    GitHub
                </a>
                <a
                    href="https://twitter.com/manpuccc"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-twitter"
                >
                    <svg
                        class="contact-icon twitter-icon"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"
                        ></path>
                    </svg>
                    Twitter
                </a>
            </div>
        </section>
    </div>
</Layout>
