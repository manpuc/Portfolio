---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import avatarImg from "../../public/avatar.webp";
import { works } from "../data/works";
import TechIcon from "../components/TechIcon.astro";

import { devSkills, toolSkills } from "../data/skills";

// Helper to convert devicon class to simple TechIcon keys
const getIconName = (deviconClass: string) => {
    const mapping: Record<string, string> = {
        "devicon-html5-plain": "html",
        "devicon-css3-plain": "css",
        "devicon-javascript-plain": "javascript",
        "devicon-astro-plain": "astro",
        "devicon-react-original": "react",
        "devicon-nodejs-plain": "nodejs",
        "devicon-python-plain": "python",
        "devicon-bash-plain": "powershell",
        "devicon-java-plain": "java",
        "devicon-git-plain": "git",
        "devicon-github-original": "github",
        "devicon-vscode-plain": "vscode",
        "devicon-aftereffects-plain": "aftereffects",
        "devicon-illustrator-plain": "illustrator",
    };
    return mapping[deviconClass] || "html";
};
---

<Layout title="manpuc | Student Developer & UI/UX Designer" lang="ja">
    <div class="container main-content">
        <header class="main-header">
            <div
                class="profile-img-container animate-profile-pop delay-profile"
            >
                <Image
                    src={avatarImg}
                    width={150}
                    height={150}
                    alt="manpuc"
                    class="profile-img"
                />
            </div>
            <div
                id="header-info"
                class="header-info animate-premium-reveal delay-header-info"
            >
                <h1>
                    <span class="sr-only">manpuc</span>
                    <span class="typewriter-container" aria-hidden="true">
                        <span class="typewriter-text" data-text="manpuc"></span>
                        <span class="typewriter-cursor"></span>
                    </span>
                </h1>
                <p class="subtitle">@manpuc / Developer & Creator</p>
            </div>
        </header>

        <div class="header-divider animate-premium-reveal delay-divider"></div>

        <section id="works" class="works-section animate-fade-up delay-3">
            <h2>Works</h2>
            <div class="marquee-container">
                <div class="marquee-content">
                    {
                        [...works, ...works].map((work) => (
                            <a
                                href={work.href}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="marquee-item"
                            >
                                {work.title.ja}
                            </a>
                        ))
                    }
                </div>
            </div>
            <div class="works-all-link-container">
                <a
                    href="/works/"
                    class="forward-link"
                    aria-label="制作実績をすべて表示"
                >
                    制作実績をすべて見る
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        role="img"
                        aria-label="矢印アイコン"
                        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                            points="12 5 19 12 12 19"></polyline></svg
                    >
                </a>
            </div>
        </section>

        <section id="skills" class="skills-section animate-fade-up delay-4">
            <h2>Skills</h2>
            <div class="skills-group">
                <h3 class="skills-category-title">Dev & Code</h3>
                <div class="tags">
                    {
                        devSkills.map((skill) => (
                            <span
                                class="tag"
                                style={`--tag-color: ${skill.color}; --tag-text: ${skill.textColor};`}
                            >
                                <TechIcon name={getIconName(skill.icon)} />{" "}
                                {skill.name}
                            </span>
                        ))
                    }
                </div>
            </div>
            <div class="skills-group">
                <h3 class="skills-category-title">Tools & Others</h3>
                <div class="tags">
                    {
                        toolSkills.map((skill) => (
                            <span
                                class="tag"
                                style={`--tag-color: ${skill.color}; --tag-text: ${skill.textColor};`}
                            >
                                <TechIcon name={getIconName(skill.icon)} />{" "}
                                {skill.name}
                            </span>
                        ))
                    }
                </div>
            </div>
        </section>

        <section id="about" class="about-section animate-fade-up delay-5">
            <h2>About</h2>
            <p class="about-text">
                高校商業科情報デザイン類型を卒業し、現在は放送大学教養学部社会と産業コースに在籍しています。スマートウォッチやスマホなどのガジェット収集を趣味としつつ、Minecraft
                Mod開発、Bot制作、Chrome拡張機能制作など、新しい技術に触れながらモノづくりをすることに情熱を注いでいます。お仕事募集中です。
            </p>
        </section>

        <script>
            import { initGravityEasterEgg } from "../scripts/gravity";
            import { initTypewriter } from "../scripts/typewriter";
            import { setupMarquee } from "../scripts/marquee";

            initGravityEasterEgg();
            initTypewriter();
            setupMarquee();
        </script>
    </div>
</Layout>
