---
import Layout from "../layouts/Layout.astro";
import ErrorPage from "../components/ErrorPage.astro";
---

<Layout title="500 Internal Server Error | Kouki Fujikawa" isErrorPage={true}>
  <ErrorPage
    code={500}
    titleJa="サーバーエラーが発生しました"
    titleEn="Internal Server Error"
    descJa="サーバー側で問題が発生しました。<br />しばらく時間をおいてから再度お試しください。"
    descEn="Something went wrong on our end.<br />Please try again later."
    gradient="linear-gradient(135deg, var(--red), #ff6b35)"
  />
</Layout>
